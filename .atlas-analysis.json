  "keyFeatures": [
    "Unified multi-provider architecture (Ollama, OpenAI, Gemini, Groq, Azure, Anthropic)",
    "Native streaming with hidden reasoning token extraction",
    "Zero-config tool integration via Python type hints and docstrings",
    "Built-in persistent memory with semantic vector search (RAG)",
    "Agent-aware cron job scheduler for autonomous background tasks",
    "Pre-built skills (web_research, code_review, file_manipulation)",
    "Model Context Protocol (MCP) integration for dynamic external tools",
    "Flexible tool approval and safety workflows",
    "Multi-session management with full conversation history",
    "Built-in telemetry and observability"
  ],
